{
  "name": "cms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && npm run dev",
    "build": "prisma generate && node scripts/ensure-upload-dir.js && next build",
    "start": "node scripts/ensure-upload-dir.js && next start",
    "start:prod": "node scripts/ensure-upload-dir.js && next start",
    "prod": "npm run build && npm run start:prod",
    "prod:only": "npm run start:prod",
    "postinstall": "prisma generate && node scripts/ensure-upload-dir.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "framer-motion": "^12.40.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-quill-new": "^3.8.3",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.0",
    "tailwindcss": "^4"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
